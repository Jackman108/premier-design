# Dev-образ: контекст сборки — корень репозитория (как febcode: package.json + src/).
# См. Dockerfile.prod / .nvmrc — Node 24.
FROM node:24-alpine

RUN apk add --no-cache libc6-compat wget

WORKDIR /app

COPY package.json yarn.lock ./
# См. Dockerfile.prod — в базовом образе уже есть `yarn`
RUN yarn install --frozen-lockfile --ignore-scripts

COPY . .

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
	CMD wget -qO- http://127.0.0.1:3000/ || exit 1

# По умолчанию — Turbopack (`package.json` → `yarn dev`). Для Webpack: переопределите CMD на `yarn dev:webpack`.
CMD ["yarn", "dev"]
