# Скопировать: cp -n febcode.env.example febcode.env
# Секреты и публичные URL — см. чеклист / README в репозитории febcode
#
# Локальный запуск под nginx (http://febcode.pro:8080) — не коммитить `febcode.env`.

NODE_ENV=production
NEXT_PUBLIC_SITE_URL=http://febcode.pro:8080

# Минимум для заявок в Telegram (раскомментируйте при тесте API)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_TOKEN=   # alias, если в febcode используется другое имя

# Публичные ключи / аналитика / reCAPTCHA / Upstash — см. документацию febcode
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# NEXT_PUBLIC_YANDEX_METRIKA_ID=
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=
