# Скопировать: cp -n premium-design.env.example premium-design.env  (Windows: copy)
# Полный перечень — см. premier-design/.env.example
#
# Локальный запуск под nginx (http://premium-design.pro:8080) — не коммитить `premium-design.env`.

NODE_ENV=production
RATE_LIMIT_TRUST_FORWARDED_FOR=1
# Локальный nginx по HTTP (:8080): без HSTS из Next (TLS на проде — у nginx).
ENABLE_HTTPS_SECURITY_HEADERS=false
# Запретить HSTS из Next при случайном VERCEL=1 в .env (образ должен быть собран с актуальным next.config.js).
LOCAL_HTTP_STACK=1

# Ниже — при тесте форм / e-mail; можно оставить пусто для smoke главной
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USERNAME=
# EMAIL_PASSWORD=
# FEEDBACK_EMAIL_TO=
# NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
