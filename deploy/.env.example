# Скопировать как `deploy/.env`. Никогда не коммитить заполненный `.env`!

# Образы из GHCR (каждый сайт публикует из своего CI).
# Имя образа рекомендуется `premium-design` (согласовано с доменом и сервисом compose).
PREMIUM_DESIGN_IMAGE=ghcr.io/<owner>/premium-design:latest
FEBCODE_IMAGE=ghcr.io/<owner>/febcode:latest

# Контактный e-mail для Let's Encrypt (notifications об истечении сертификатов).
LETSENCRYPT_EMAIL=admin@premium-design.pro

# Внутренние секреты приложений лежат в `deploy/secrets/<app>.env`
# (отдельные файлы, чтобы один сайт не видел переменных другого).
