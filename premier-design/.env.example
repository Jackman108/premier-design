# Runtime
NODE_ENV=development

# Vercel: выставляется платформой (1) — включает HSTS в next.config.js (CSP без upgrade-insecure-requests).
# VERCEL=

# Self-hosted за HTTPS-прокси: true — заголовок Strict-Transport-Security. На голом HTTP (локально, docker :8080) — false.
# ENABLE_HTTPS_SECURITY_HEADERS=true

# За доверенным прокси (Vercel и т.п.) — учитывать x-forwarded-for для rate limit API
RATE_LIMIT_TRUST_FORWARDED_FOR=

# API integrations for feedback processing
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
# HTTP timeout axios→api.telegram.org (мс; по умолчанию 8000; 2 ретрая в submitFeedback ≈ 2×значение)
# TELEGRAM_REQUEST_TIMEOUT_MS=8000

# Письмо с формы — только если задан EMAIL_HOST; Telegram отправляется всегда (нужны TELEGRAM_*).
# Email transport
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USERNAME=mailer@example.com
EMAIL_PASSWORD=change_me

# Куда слать письмо (обязательно для доставки, если заданы EMAIL_HOST и остальные поля)
FEEDBACK_EMAIL_TO=owner@example.com
# От кого (если пусто — используется EMAIL_USERNAME)
FEEDBACK_EMAIL_FROM=

# Надёжность /api/feedback (RISK-10; по умолчанию — дефолты в коде, см. реестр рисков)
# FEEDBACK_CIRCUIT_ENABLED=true
# FEEDBACK_CIRCUIT_FAILURE_THRESHOLD=5
# FEEDBACK_CIRCUIT_OPEN_MS=60000
# Таймаут HTTP-обработчика (retry+Telegram; по умолчанию 30s в development, 20s в production)
# FEEDBACK_API_TIMEOUT_MS=20000
# FEEDBACK_SLO_ENABLED=true

# Optional public keys
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=

# Аналитика (после согласования с CSP и cookies — см. docs/adr/0009-web-analytics-deferred.md)
# NEXT_PUBLIC_YM_ID=

# Сборка: отчёт bundle analyzer — открыть браузер (по умолчанию не открывается)
# ANALYZE_OPEN=true
