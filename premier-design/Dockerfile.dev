# Dev-образ: контекст сборки — каталог приложения (`./premier-design` от корня репозитория).
FROM node:20-alpine

RUN apk add --no-cache libc6-compat wget

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
	CMD wget -qO- http://127.0.0.1:3000/ || exit 1

CMD ["npm", "run", "dev"]
